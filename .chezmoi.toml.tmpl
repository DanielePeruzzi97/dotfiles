{{- /* Chezmoi configuration template — processed once on `chezmoi init` */ -}}

{{- $name        := "User" -}}
{{- $email       := "user@example.com" -}}
{{- $signingkey  := "" -}}
{{- $profile     := "workstation" -}}
{{- $compositor  := "both" -}}
{{- $personal    := false -}}
{{- $ageRecipient := "age17v8ymwgcczxthzjg6kpfduxqyhgf0n93csvzz3ra5xylnc6uk3vqx4enpy" -}}

{{- if stdinIsATTY -}}
{{-   $name       = promptStringOnce . "name"       "Your full name" -}}
{{-   $email      = promptStringOnce . "email"      "Your email address" -}}
{{-   $signingkey = promptStringOnce . "signingkey" "GPG signing key id (blank to skip)" "" -}}
{{-   $profile    = promptChoiceOnce . "profile"    "Profile (minimal|workstation)" (list "minimal" "workstation") "workstation" -}}
{{-   if eq $profile "workstation" -}}
{{-     $compositor = promptChoiceOnce . "compositor" "Compositor (niri|hyprland|both)" (list "niri" "hyprland" "both") "both" -}}
{{-   end -}}
{{-   $personal = promptBoolOnce . "personal" "Personal machine (enable private dotfiles + age decryption)" -}}
{{-   if $personal -}}
{{-     $ageRecipient = promptStringOnce . "age_recipient" "Age recipient public key" $ageRecipient -}}
{{-   end -}}
{{- end -}}

{{- $wantNiri     := or (eq $compositor "niri")     (eq $compositor "both") -}}
{{- $wantHyprland := or (eq $compositor "hyprland") (eq $compositor "both") -}}

{{- /* Distro detection — fail closed: only arch + ubuntu 25.10 supported */ -}}
{{- $osid := "" -}}
{{- $codename := "" -}}
{{- if hasKey .chezmoi.osRelease "id" -}}{{- $osid = .chezmoi.osRelease.id -}}{{- end -}}
{{- if hasKey .chezmoi.osRelease "versionCodename" -}}{{- $codename = .chezmoi.osRelease.versionCodename -}}{{- end -}}

{{- $isArch   := eq $osid "arch" -}}
{{- $isUbuntu := and (eq $osid "ubuntu") (eq $codename "questing") -}}

sourceDir = {{ .chezmoi.sourceDir | quote }}
{{- if $personal }}
encryption = "age"
{{- end }}

[data]
    name       = {{ $name       | quote }}
    email      = {{ $email      | quote }}
    signingkey = {{ $signingkey | quote }}
    profile    = {{ $profile    | quote }}
    compositor = {{ $compositor | quote }}

    want_niri     = {{ $wantNiri     }}
    want_hyprland = {{ $wantHyprland }}

    osid      = {{ $osid     | quote }}
    codename  = {{ $codename | quote }}
    is_arch   = {{ $isArch   }}
    is_ubuntu = {{ $isUbuntu }}

    personal      = {{ $personal }}
    age_recipient = {{ $ageRecipient | quote }}

[edit]
    command = "nvim"

[git]
    autoCommit = true
    autoPush   = true

{{- if $personal }}
[age]
    identity  = "{{ .chezmoi.homeDir }}/.config/chezmoi/key.txt"
    recipient = {{ $ageRecipient | quote }}
{{- end }}
