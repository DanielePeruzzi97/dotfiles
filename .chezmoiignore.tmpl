.config/hypr/
.config/hyprdynamicmonitors/
.config/niri/
.config/waybar/
.config/rofi/
.config/swaync/
.config/wlogout/
.config/k9s/
.config/gtk-3.0/
.config/gtk-4.0/
.config/qt5ct/
.config/qt6ct/
{{- end }}

{{- if and (eq .profile "workstation") (not .want_niri) }}
# Niri not selected
.config/niri/
{{- end }}
{{- if and (eq .profile "workstation") (not .want_hyprland) }}
# Hyprland not selected
.config/hypr/
.config/hyprdynamicmonitors/
