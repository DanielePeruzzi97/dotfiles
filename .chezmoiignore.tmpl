# Chezmoi ignore rules
# Files in this list are excluded from management

# Repository files (never sync to home)
README.md
LICENSE
Vagrantfile
setup.sh
.stow-local-ignore
bootstrap.private.env.age
bootstrap.private.env.age.example

# Legacy install scripts (kept for reference but not synced)
install.sh
install/
dotfiles.sh
scripts/check-manual-updates.sh

# Legacy stow layout kept temporarily for migration safety.
# Must never be applied by chezmoi.
alacritty/
bin/
ghostty/
git/
hyprland/
k9s/
nvim/
opencode/
scripts/
tmux/
topgrade/
zen/
zshrc/

# Desktop-specific configs (only if desktop not installed)
{{- if not .install_desktop }}
.config/hypr/
.config/waybar/
.config/rofi/
.config/swaync/
.config/swayosd/
.config/wlogout/
.config/hyprdynamicmonitors/
{{- end }}

# Kubernetes configs (only if k8s not installed)
{{- if not .install_k8s }}
.config/k9s/
{{- end }}

# OS-specific ignores
{{- if eq .chezmoi.os "darwin" }}
# macOS doesn't need these Linux-specific configs
.config/hypr/
.config/waybar/
.config/rofi/
.config/swaync/
.config/swayosd/
.config/wlogout/
{{- end }}

# Windows-specific configs on Linux
{{- if ne .chezmoi.os "windows" }}
.config/alacritty/alacritty.toml.windows
{{- end }}

