#!/usr/bin/env bash
# Install Hyprland plugins (hyprsplit) — workstation only, requires running Hyprland session.
set -euo pipefail

{{ if ne .profile "workstation" -}}
exit 0
{{- end }}

if ! command -v hyprpm >/dev/null; then
    echo "hyprpm not found, skipping Hyprland plugins"
    exit 0
fi

if [ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]; then
    echo "Hyprland not running; plugins will be installed on first Hyprland start"
    exit 0
fi

echo "Updating hyprpm…"
hyprpm update

if ! hyprpm list 2>/dev/null | grep -q "hyprsplit.*enabled: true"; then
    echo "Installing hyprsplit…"
    hyprpm add https://github.com/shezdy/hyprsplit || { echo "hyprsplit add failed"; exit 0; }
    hyprpm enable hyprsplit
fi
echo "Hyprland plugins done"
