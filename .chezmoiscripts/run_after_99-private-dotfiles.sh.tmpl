#!/usr/bin/env bash
# Clone and apply private dotfiles (if available)
# This runs after the main dotfiles are applied
# Uses decrypted bootstrap token for HTTPS authentication

set -euo pipefail

PRIVATE_REPO="https://github.com/DanielePeruzzi97/dotfiles_private.git"
PRIVATE_DIR="$HOME/.dotfiles_private"
BOOTSTRAP_ENV_FILE="$HOME/.local/share/dotfiles/bootstrap.private.env"

if [ -f "$BOOTSTRAP_ENV_FILE" ]; then
    # shellcheck disable=SC1090
    set -a
    . "$BOOTSTRAP_ENV_FILE"
    set +a
fi

echo "Setting up private dotfiles..."

if [ -z "${GITHUB_TOKEN:-}" ]; then
    echo "Warning: GITHUB_TOKEN not found in decrypted bootstrap env"
    echo "Skipping private dotfiles setup"
    exit 0
fi

AUTH_REPO="https://x-access-token:${GITHUB_TOKEN}@github.com/DanielePeruzzi97/dotfiles_private.git"

echo "Testing private repo access with decrypted bootstrap token..."
if ! git ls-remote "$AUTH_REPO" HEAD >/dev/null 2>&1; then
    echo "Warning: Cannot authenticate to private repo with bootstrap token"
    echo "Skipping private dotfiles setup"
    exit 0
fi

# Clone or update private repo
if [ -d "$PRIVATE_DIR/.git" ]; then
    echo "Private dotfiles repo exists, pulling latest..."
    cd "$PRIVATE_DIR"
    git fetch "$AUTH_REPO"
    git checkout feat/chezmoi-migration 2>/dev/null || git checkout main
    git pull "$AUTH_REPO"
else
    echo "Cloning private dotfiles..."
    git clone --branch feat/chezmoi-migration "$AUTH_REPO" "$PRIVATE_DIR" 2>/dev/null || \
    git clone "$AUTH_REPO" "$PRIVATE_DIR"
fi

echo "Private dotfiles repository synchronized"
echo "Deferred apply to installer step to avoid chezmoi state lock"
