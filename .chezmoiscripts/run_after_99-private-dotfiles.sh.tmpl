#!/usr/bin/env bash
# Clone and apply private dotfiles (if available)
# This runs after the main dotfiles are applied
# Requires a pre-generated YubiKey SSH key at ~/.ssh/id_ed25519_sk

set -euo pipefail

{{- if not .is_work_machine }}
# Skip private dotfiles for non-work machines
echo "Skipping private dotfiles (not a work machine)"
exit 0
{{- end }}

PRIVATE_REPO="git@github.com:DanielePeruzzi97/dotfiles_private.git"
PRIVATE_DIR="$HOME/.dotfiles_private"
PRIVATE_KEY="$HOME/.ssh/id_ed25519_sk"
SSH_CMD="ssh -i $PRIVATE_KEY -o IdentitiesOnly=yes -o PreferredAuthentications=publickey"

echo "Setting up private dotfiles..."

if [ ! -f "$PRIVATE_KEY" ]; then
    echo "Warning: YubiKey SSH key not found at $PRIVATE_KEY"
    echo "Generate/import it first, then re-run: chezmoi apply"
    exit 0
fi

chmod 600 "$PRIVATE_KEY" 2>/dev/null || true

# Test private repo access with YubiKey key only
echo "Testing private repo SSH access with YubiKey key..."
if ! GIT_SSH_COMMAND="$SSH_CMD" git ls-remote "$PRIVATE_REPO" HEAD >/dev/null 2>&1; then
    echo "Warning: Cannot authenticate to private repo with YubiKey key"
    echo "Skipping private dotfiles setup"
    echo ""
    echo "To set up later:"
    echo "  1. Ensure ~/.ssh/id_ed25519_sk exists and GitHub has the matching public key"
    echo "  2. Run: chezmoi apply"
    exit 0
fi

# Clone or update private repo
if [ -d "$PRIVATE_DIR/.git" ]; then
    echo "Private dotfiles repo exists, pulling latest..."
    cd "$PRIVATE_DIR"
    GIT_SSH_COMMAND="$SSH_CMD" git fetch origin
    git checkout feat/chezmoi-migration 2>/dev/null || git checkout main
    GIT_SSH_COMMAND="$SSH_CMD" git pull
else
    echo "Cloning private dotfiles..."
    GIT_SSH_COMMAND="$SSH_CMD" git clone --branch feat/chezmoi-migration "$PRIVATE_REPO" "$PRIVATE_DIR" 2>/dev/null || \
    GIT_SSH_COMMAND="$SSH_CMD" git clone "$PRIVATE_REPO" "$PRIVATE_DIR"
fi

# Apply private dotfiles using chezmoi
echo "Applying private dotfiles..."

# Use chezmoi with the private source directory
if command -v mise &>/dev/null; then
    mise exec chezmoi@latest -- chezmoi apply --source="$PRIVATE_DIR" --destination="$HOME"
else
    chezmoi apply --source="$PRIVATE_DIR" --destination="$HOME"
fi

echo "Private dotfiles applied successfully"
