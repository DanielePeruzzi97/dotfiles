#!/usr/bin/env bash
# Clone and apply private dotfiles (if available)
# This runs after the main dotfiles are applied
#
# Bootstrap (first run): Uses YubiKey-decrypted GITHUB_TOKEN to clone
# Subsequent runs: Uses SSH keys (already set up by private dotfiles)

set -euo pipefail

PRIVATE_DIR="$HOME/.dotfiles_private"
PRIVATE_REPO_SSH="git@github.com:DanielePeruzzi97/dotfiles_private.git"
PRIVATE_REPO_HTTPS="https://github.com/DanielePeruzzi97/dotfiles_private.git"
BOOTSTRAP_ENV_FILE="$HOME/.local/share/dotfiles/bootstrap.private.env"

# If private repo already exists, just pull with existing credentials (SSH)
if [ -d "$PRIVATE_DIR/.git" ]; then
    echo "Updating private dotfiles..."
    cd "$PRIVATE_DIR"
    
    # Try SSH first (normal case after bootstrap)
    if git pull origin 2>/dev/null; then
        echo "Private dotfiles updated"
    else
        echo "Warning: Could not pull private dotfiles (check SSH keys)"
    fi
    exit 0
fi

# First run: need to clone using bootstrap token
echo "Setting up private dotfiles (first run)..."

# Load bootstrap env if available
if [ -f "$BOOTSTRAP_ENV_FILE" ]; then
    # shellcheck disable=SC1090
    set -a
    . "$BOOTSTRAP_ENV_FILE"
    set +a
fi

# Try SSH first (if keys already exist from manual setup)
if ssh -o BatchMode=yes -o ConnectTimeout=5 git@github.com 2>&1 | grep -q "successfully authenticated"; then
    echo "Cloning private dotfiles via SSH..."
    if git clone --branch feat/chezmoi-migration "$PRIVATE_REPO_SSH" "$PRIVATE_DIR" 2>/dev/null || \
       git clone "$PRIVATE_REPO_SSH" "$PRIVATE_DIR"; then
        echo "Private dotfiles cloned via SSH"
        exit 0
    fi
fi

# Fall back to HTTPS with bootstrap token
if [ -z "${GITHUB_TOKEN:-}" ]; then
    echo "Warning: GITHUB_TOKEN not found and SSH not available"
    echo "Skipping private dotfiles setup"
    echo "To set up manually:"
    echo "  git clone $PRIVATE_REPO_SSH $PRIVATE_DIR"
    exit 0
fi

AUTH_REPO="https://x-access-token:${GITHUB_TOKEN}@github.com/DanielePeruzzi97/dotfiles_private.git"

echo "Testing private repo access with bootstrap token..."
if ! git ls-remote "$AUTH_REPO" HEAD >/dev/null 2>&1; then
    echo "Warning: Cannot authenticate to private repo"
    echo "Skipping private dotfiles setup"
    exit 0
fi

echo "Cloning private dotfiles via HTTPS (bootstrap)..."
if git clone --branch feat/chezmoi-migration "$AUTH_REPO" "$PRIVATE_DIR" 2>/dev/null || \
   git clone "$AUTH_REPO" "$PRIVATE_DIR"; then
    
    # Switch remote to SSH for future pulls (no token needed)
    cd "$PRIVATE_DIR"
    git remote set-url origin "$PRIVATE_REPO_SSH"
    echo "Private dotfiles cloned, remote switched to SSH for future updates"
else
    echo "Warning: Failed to clone private dotfiles"
    exit 0
fi

# Create apply script
APPLY_SCRIPT="$HOME/.local/share/dotfiles/apply-private-dotfiles.sh"
cat > "$APPLY_SCRIPT" << 'SCRIPT'
#!/usr/bin/env bash
PRIVATE_DIR="$HOME/.dotfiles_private"
if [ ! -d "$PRIVATE_DIR" ]; then
    echo "Private dotfiles not found at $PRIVATE_DIR"
    exit 1
fi
echo "Applying private dotfiles with chezmoi..."
chezmoi apply --source="$PRIVATE_DIR"
SCRIPT
chmod +x "$APPLY_SCRIPT"

echo ""
echo "==================================================="
echo "Private dotfiles cloned. Run to apply:"
echo "  $APPLY_SCRIPT"
echo "==================================================="
