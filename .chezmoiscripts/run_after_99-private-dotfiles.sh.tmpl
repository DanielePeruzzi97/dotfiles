#!/usr/bin/env bash
# Clone and apply private dotfiles (if available)
# This runs after the main dotfiles are applied
# Requires YubiKey resident SSH key for authentication

set -euo pipefail

{{- if not .is_work_machine }}
# Skip private dotfiles for non-work machines
echo "Skipping private dotfiles (not a work machine)"
exit 0
{{- end }}

PRIVATE_REPO="git@github.com:DanielePeruzzi97/dotfiles_private.git"
PRIVATE_DIR="$HOME/.dotfiles_private"

echo "Setting up private dotfiles..."

# Check if ssh-agent has any keys loaded
if ! ssh-add -l &>/dev/null; then
    echo "No SSH keys loaded. Attempting to load YubiKey resident key..."
    
    # Try to load resident key from YubiKey
    if command -v ssh-keygen &>/dev/null; then
        echo "Insert your YubiKey and touch it when prompted..."
        ssh-keygen -K 2>/dev/null || {
            echo "Warning: Could not load YubiKey resident key"
            echo "You can manually run: ssh-keygen -K"
            echo "Then re-run: chezmoi apply"
            exit 0
        }
        
        # Add the downloaded key to agent
        if [ -f "$HOME/id_ed25519_sk" ]; then
            mv "$HOME/id_ed25519_sk" "$HOME/.ssh/id_ed25519_sk"
            mv "$HOME/id_ed25519_sk.pub" "$HOME/.ssh/id_ed25519_sk.pub" 2>/dev/null || true
            chmod 600 "$HOME/.ssh/id_ed25519_sk"
            ssh-add "$HOME/.ssh/id_ed25519_sk"
        fi
    fi
fi

# Test GitHub SSH access
echo "Testing GitHub SSH access..."
if ! ssh -T git@github.com 2>&1 | grep -q "successfully authenticated"; then
    echo "Warning: Cannot authenticate to GitHub via SSH"
    echo "Skipping private dotfiles setup"
    echo ""
    echo "To set up later:"
    echo "  1. Load your SSH key (e.g., ssh-add or insert YubiKey)"
    echo "  2. Run: chezmoi apply"
    exit 0
fi

# Clone or update private repo
if [ -d "$PRIVATE_DIR/.git" ]; then
    echo "Private dotfiles repo exists, pulling latest..."
    cd "$PRIVATE_DIR"
    git fetch origin
    git checkout feat/chezmoi-migration 2>/dev/null || git checkout main
    git pull
else
    echo "Cloning private dotfiles..."
    git clone --branch feat/chezmoi-migration "$PRIVATE_REPO" "$PRIVATE_DIR" 2>/dev/null || \
    git clone "$PRIVATE_REPO" "$PRIVATE_DIR"
fi

# Apply private dotfiles using chezmoi
echo "Applying private dotfiles..."

# Use chezmoi with the private source directory
if command -v mise &>/dev/null; then
    mise exec chezmoi@latest -- chezmoi apply --source="$PRIVATE_DIR" --destination="$HOME"
else
    chezmoi apply --source="$PRIVATE_DIR" --destination="$HOME"
fi

echo "Private dotfiles applied successfully"
