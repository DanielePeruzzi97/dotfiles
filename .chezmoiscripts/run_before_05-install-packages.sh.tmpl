{{- /* Install packages by profile + distro + compositor */ -}}
{{- /* packages hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }} */ -}}
#!/usr/bin/env bash
set -euo pipefail

info() { printf "\033[0;34m[*]\033[0m %s\n" "$*"; }
ok()   { printf "\033[0;32m[+]\033[0m %s\n" "$*"; }
warn() { printf "\033[1;33m[!]\033[0m %s\n" "$*"; }

PROFILE="{{ .profile }}"
COMPOSITOR="{{ .compositor }}"

# --- Build distro-specific package list ---------------------------------------
PKGS=(
{{- range .packages.minimal.common }}
    "{{ . }}"
{{- end }}
{{- if .is_arch }}
{{-   range .packages.minimal.arch }}
    "{{ . }}"
{{-   end }}
{{- else if .is_ubuntu }}
{{-   range .packages.minimal.ubuntu }}
    "{{ . }}"
{{-   end }}
{{- end }}

{{- if eq .profile "workstation" }}
{{-   range .packages.workstation.common }}
    "{{ . }}"
{{-   end }}
{{-   if .is_arch }}
{{-     range .packages.workstation.arch }}
    "{{ . }}"
{{-     end }}
{{-   else if .is_ubuntu }}
{{-     range .packages.workstation.ubuntu }}
    "{{ . }}"
{{-     end }}
{{-   end }}

{{-   if .want_niri }}
{{-     range .packages.workstation.niri.common }}
    "{{ . }}"
{{-     end }}
{{-     if .is_arch }}
{{-       range .packages.workstation.niri.arch }}
    "{{ . }}"
{{-       end }}
{{-     else if .is_ubuntu }}
{{-       range .packages.workstation.niri.ubuntu }}
    "{{ . }}"
{{-       end }}
{{-     end }}
{{-   end }}

{{-   if .want_hyprland }}
{{-     range .packages.workstation.hyprland.common }}
    "{{ . }}"
{{-     end }}
{{-     if .is_arch }}
{{-       range .packages.workstation.hyprland.arch }}
    "{{ . }}"
{{-       end }}
{{-     else if .is_ubuntu }}
{{-       range .packages.workstation.hyprland.ubuntu }}
    "{{ . }}"
{{-       end }}
{{-     end }}
{{-   end }}
{{- end }}
)

# --- Install --------------------------------------------------------------------
{{ if .is_ubuntu -}}
info "Ubuntu apt update"
sudo apt update

# Neovim PPA — Ubuntu 25.10 ships an older neovim, we want 0.12+
if ! grep -rq "neovim-ppa" /etc/apt/sources.list.d/ 2>/dev/null; then
    info "Adding neovim unstable PPA (for nvim 0.12+)"
    sudo add-apt-repository -y ppa:neovim-ppa/unstable
    sudo apt update
fi

# DMS PPA — required before installing the dms package in workstation profile
{{ if eq .profile "workstation" -}}
if ! grep -rq "avengemedia/dms" /etc/apt/sources.list.d/ 2>/dev/null; then
    info "Adding DMS + danklinux PPAs"
    sudo add-apt-repository -y ppa:avengemedia/danklinux
    sudo add-apt-repository -y ppa:avengemedia/dms
    sudo apt update
fi

{{   if .want_hyprland -}}
# Hyprland PPA — Ubuntu apt doesn't carry hyprlock/hypridle/hyprsunset/hyprpaper
if ! grep -rq "cppiber/hyprland" /etc/apt/sources.list.d/ 2>/dev/null; then
    info "Adding hyprland PPA (cppiber)"
    sudo add-apt-repository -y ppa:cppiber/hyprland
    sudo apt update
fi
{{-   end }}
{{- end }}

info "Installing ${#PKGS[@]} apt packages"
sudo apt install -y "${PKGS[@]}"

# Symlink fd-find -> fd (Ubuntu ships it as fdfind)
if command -v fdfind >/dev/null && ! command -v fd >/dev/null; then
    mkdir -p "$HOME/.local/bin"
    ln -sf "$(command -v fdfind)" "$HOME/.local/bin/fd"
    ok "Symlinked fd-find -> ~/.local/bin/fd"
fi

{{ if eq .profile "workstation" -}}
# ghostty — official .deb via mkasberg installer (supports 24.04/25.10/26.04)
if ! command -v ghostty >/dev/null; then
    info "Installing ghostty via mkasberg installer"
    # run from /tmp so the downloaded .deb is in a dir readable by apt's _apt sandbox user
    # (apt cannot access files under $HOME with default mode 700)
    ( cd /tmp && /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/mkasberg/ghostty-ubuntu/HEAD/install.sh)" ) \
        || warn "ghostty install failed"
fi

{{   if .want_hyprland -}}
# hyprdynamicmonitors — pinned v1.4.0 release tarball (no apt source)
HDM_VERSION="v1.4.0"
if [ -x /usr/local/bin/hyprdynamicmonitors ]; then
    HDM_INSTALLED_VERSION="$(/usr/local/bin/hyprdynamicmonitors --version 2>/dev/null | awk '{print "v"$2}' | head -1)"
else
    HDM_INSTALLED_VERSION=""
fi
if [ "$HDM_INSTALLED_VERSION" != "$HDM_VERSION" ]; then
    info "Installing hyprdynamicmonitors $HDM_VERSION"
    HDM_TMP="$(mktemp -d)"
    trap 'rm -rf "$HDM_TMP"' EXIT
    HDM_URL="https://github.com/fiffeek/hyprdynamicmonitors/releases/download/${HDM_VERSION}/hyprdynamicmonitors_Linux_x86_64.tar.gz"
    if curl -fsSL "$HDM_URL" -o "$HDM_TMP/hdm.tar.gz"; then
        tar -xzf "$HDM_TMP/hdm.tar.gz" -C "$HDM_TMP"
        sudo install -m 0755 "$HDM_TMP"/hyprdynamicmonitors /usr/local/bin/hyprdynamicmonitors
        # Systemd units shipped in tarball under systemd/user/
        if [ -d "$HDM_TMP/systemd/user" ]; then
            sudo install -m 0644 "$HDM_TMP/systemd/user/"*.service /etc/systemd/user/
        fi
        ok "hyprdynamicmonitors $HDM_VERSION installed"
    else
        warn "hyprdynamicmonitors download failed"
    fi
    trap - EXIT
    rm -rf "$HDM_TMP"
fi
{{-   end }}
{{- end }}

{{ else if .is_arch -}}
info "Arch pacman -Syu"
sudo pacman -Syu --noconfirm --needed

info "Installing ${#PKGS[@]} pacman packages"
sudo pacman -S --noconfirm --needed "${PKGS[@]}"

{{   if eq .profile "workstation" -}}
# AUR via paru (installed in the pacman pass above)
AUR_PKGS=(
{{-   range .packages.workstation.aur }}
    "{{ . }}"
{{-   end }}
{{-   if .want_hyprland }}
{{-     range .packages.workstation.hyprland.aur }}
    "{{ . }}"
{{-     end }}
{{-   end }}
)
if command -v paru >/dev/null && [ "${#AUR_PKGS[@]}" -gt 0 ]; then
    info "Installing ${#AUR_PKGS[@]} AUR packages via paru"
    paru -S --noconfirm --needed "${AUR_PKGS[@]}"
else
    warn "paru not available — skipping AUR packages"
fi
{{-   end }}
{{- end }}

# --- Flatpak (workstation only) ------------------------------------------------
{{ if eq .profile "workstation" -}}
if command -v flatpak >/dev/null; then
    info "Configuring flathub remote"
    sudo flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
    FPKGS=(
{{-   range .packages.workstation.flatpak }}
        "{{ . }}"
{{-   end }}
    )
    info "Installing ${#FPKGS[@]} flatpaks (system-wide)"
    sudo flatpak install -y --noninteractive flathub "${FPKGS[@]}" || warn "Some flatpaks failed"
fi
{{- end }}

ok "Package installation complete"
