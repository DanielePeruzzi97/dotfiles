{{- /* Run mise install when config changes */ -}}
{{- /* Hash of mise config to trigger on changes: */ -}}
{{- /* {{ include "dot_config/mise/config.toml" | sha256sum }} */ -}}
#!/bin/bash
set -e

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[WARN]${NC} $1"; }

detect_distro() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        echo "$ID"
    elif [ -f /etc/arch-release ]; then
        echo "arch"
    else
        echo "unknown"
    fi
}

ensure_age_prereqs() {
    local distro
    distro=$(detect_distro)

    if ! command -v age >/dev/null 2>&1; then
        case "$distro" in
            ubuntu|debian|pop)
                sudo apt install -y age >/dev/null 2>&1 || return 1
                ;;
            arch|manjaro|cachyos|endeavouros)
                sudo pacman -S --noconfirm --needed age >/dev/null 2>&1 || return 1
                ;;
            *)
                return 1
                ;;
        esac
    fi

    if ! command -v age-plugin-yubikey >/dev/null 2>&1; then
        case "$distro" in
            ubuntu|debian|pop)
                sudo apt install -y --no-install-recommends cargo pkg-config libpcsclite-dev pcscd scdaemon >/dev/null 2>&1 || return 1
                ;;
            arch|manjaro|cachyos|endeavouros)
                sudo pacman -S --noconfirm --needed rust pkgconf pcsclite yubikey-manager >/dev/null 2>&1 || return 1
                ;;
            *)
                return 1
                ;;
        esac

        command -v cargo >/dev/null 2>&1 || return 1
        cargo install age-plugin-yubikey --locked >/dev/null 2>&1 || return 1
        export PATH="$HOME/.cargo/bin:$PATH"
    fi

    return 0
}

load_bootstrap_env() {
    local env_file="$HOME/.local/share/dotfiles/bootstrap.private.env"
    local encrypted_env="$HOME/.dotfiles/bootstrap.private.env.age"
    local identity_file="$HOME/.config/age/yubikey-identities.txt"

    if [ -f "$env_file" ]; then
        # shellcheck disable=SC1090
        set -a
        . "$env_file"
        set +a
    fi

    if [ -n "${GITHUB_TOKEN:-}" ]; then
        return 0
    fi

    if [ ! -f "$encrypted_env" ]; then
        return 0
    fi

    if [ ! -s "$identity_file" ]; then
        log_warning "YubiKey identity file missing at ~/.config/age/yubikey-identities.txt"
        return 0
    fi

    if ! ensure_age_prereqs; then
        log_warning "Could not install age/age-plugin-yubikey prerequisites"
        return 0
    fi

    mkdir -p "$HOME/.local/share/dotfiles"
    log_info "Decrypting bootstrap.private.env.age for GITHUB_TOKEN (YubiKey touch required)..."
    if age -d -i "$identity_file" -o "$env_file" "$encrypted_env" 2>/dev/null; then
        chmod 600 "$env_file"
        # shellcheck disable=SC1090
        set -a
        . "$env_file"
        set +a
        if [ -n "${GITHUB_TOKEN:-}" ]; then
            log_success "Loaded GITHUB_TOKEN from decrypted bootstrap env"
        fi
    else
        log_warning "Could not decrypt bootstrap.private.env.age, continuing without GITHUB_TOKEN"
    fi
}

# Ensure mise is in PATH
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.cargo/bin:$PATH"

# Load optional bootstrap env; if needed, decrypt it now via YubiKey.
load_bootstrap_env

# Optional GitHub token to avoid API rate limits when downloading release metadata.
# User can set it beforehand (recommended in CI/VM bootstrap):
#   export GITHUB_TOKEN=ghp_xxx
if [ -n "${GITHUB_TOKEN:-}" ]; then
    export GITHUB_TOKEN
fi

if ! command -v mise &> /dev/null; then
    log_warning "mise not found, skipping tool installation"
    exit 0
fi

log_info "Installing development tools via mise..."
log_info "This may take a few minutes on first run..."

if [ -z "${GITHUB_TOKEN:-}" ]; then
    log_warning "GITHUB_TOKEN is not set; GitHub API rate limits may break some installs"
fi

# Install all tools defined in config
if ! mise install --yes; then
    if [ -z "${GITHUB_TOKEN:-}" ]; then
        log_warning "mise install failed and GITHUB_TOKEN is unset"
        log_warning "Set token and retry: export GITHUB_TOKEN=<token>; chezmoi apply"
        exit 1
    fi
    log_warning "mise install failed with token set, retrying once..."
    mise install --yes
fi

log_success "Development tools installed"

# Show installed tools
log_info "Installed tools:"
mise ls --current
