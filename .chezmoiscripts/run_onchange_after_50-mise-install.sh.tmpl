{{- /* Run mise install when config changes */ -}}
{{- /* mise config hash: {{ include "dot_config/mise/config.toml" | sha256sum }} */ -}}
#!/usr/bin/env bash
set -euo pipefail

info() { printf "\033[0;34m[*]\033[0m %s\n" "$*"; }
ok()   { printf "\033[0;32m[+]\033[0m %s\n" "$*"; }
warn() { printf "\033[1;33m[!]\033[0m %s\n" "$*"; }

export PATH="$HOME/.local/bin:$PATH"

if ! command -v mise >/dev/null; then
    warn "mise not on PATH, skipping"
    exit 0
fi

if [ -z "${GITHUB_TOKEN:-}" ]; then
    warn "GITHUB_TOKEN not set — GitHub API rate limits may break installs."
    warn "If install fails, export a token and re-run: chezmoi apply"
fi

info "Installing dev tools via mise (may take a few minutes on first run)"
mise install --yes

ok "mise install done"
mise ls --current
