{{- /* Install system packages based on distro and user preferences */ -}}
#!/bin/bash
set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Check if command exists
command_exists() {
    command -v "$1" &> /dev/null
}

{{- if .is_debian }}
# ============================================
# Debian/Ubuntu Package Installation
# ============================================

install_base_packages() {
    log_info "Installing base packages (Debian/Ubuntu)..."
    sudo apt update
    sudo apt install -y \
        zsh git stow tmux curl wget xclip \
        fzf fd-find ripgrep \
        build-essential python3-pip unzip fontconfig
    
    # fd-find symlink
    if command_exists fdfind && ! command_exists fd; then
        sudo ln -sf "$(which fdfind)" /usr/local/bin/fd
    fi
    
    log_success "Base packages installed"
}

install_neovim() {
    if command_exists nvim; then
        log_warning "Neovim already installed: $(nvim --version | head -n1)"
        return 0
    fi
    
    log_info "Installing Neovim..."
    sudo add-apt-repository -y ppa:neovim-ppa/unstable
    sudo apt update
    sudo apt install -y neovim
    log_success "Neovim installed"
}

install_ghostty() {
    if command_exists ghostty; then
        log_warning "Ghostty already installed"
        return 0
    fi
    
    log_info "Installing Ghostty..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/mkasberg/ghostty-ubuntu/HEAD/install.sh)" || {
        log_warning "Ghostty installation failed - may need manual install"
        return 0
    }
    
    if command_exists ghostty; then
        sudo update-alternatives --install /usr/bin/x-terminal-emulator x-terminal-emulator /usr/bin/ghostty 50 2>/dev/null || true
        log_success "Ghostty installed"
    fi
}

install_awscli() {
    if command_exists aws; then
        log_warning "AWS CLI already installed: $(aws --version 2>&1 | head -n1)"
        return 0
    fi

    log_info "Installing AWS CLI v2 (official installer)..."

    local arch
    local aws_zip
    arch="$(uname -m)"

    case "$arch" in
        x86_64)
            aws_zip="awscli-exe-linux-x86_64.zip"
            ;;
        aarch64|arm64)
            aws_zip="awscli-exe-linux-aarch64.zip"
            ;;
        *)
            log_warning "Unsupported architecture for AWS CLI installer: $arch"
            return 0
            ;;
    esac

    cd /tmp
    curl -fsSL "https://awscli.amazonaws.com/${aws_zip}" -o awscliv2.zip
    unzip -q -o awscliv2.zip
    sudo ./aws/install --bin-dir /usr/local/bin --install-dir /usr/local/aws-cli --update
    rm -rf /tmp/aws /tmp/awscliv2.zip

    if command_exists aws; then
        log_success "AWS CLI installed: $(aws --version 2>&1 | head -n1)"
    else
        log_warning "AWS CLI installation finished but command not found"
    fi
}

{{- if .install_desktop }}
install_desktop_packages() {
    log_info "Installing desktop packages (Debian/Ubuntu)..."
    sudo apt install -y \
        loupe gnome-text-editor file-roller \
        seahorse mpv gnome-firmware flatpak \
        curl jq tree btop iotop nethogs sshfs
    
    log_success "Desktop packages installed"
}

install_hyprland_packages() {
    log_info "Installing Hyprland packages (Debian/Ubuntu)..."

    # Match host setup: Hyprland ecosystem packages from cppiber PPA.
    if command_exists add-apt-repository; then
        if ! grep -R "cppiber/hyprland" /etc/apt/sources.list /etc/apt/sources.list.d >/dev/null 2>&1; then
            log_info "Adding Hyprland PPA (cppiber/hyprland)..."
            sudo add-apt-repository -y ppa:cppiber/hyprland
        fi
        sudo apt update
    fi

    # Install packages individually so missing ones don't fail the whole setup.
    local packages=(
        waybar sway-notification-center rofi wlogout cliphist
        wl-clipboard brightnessctl playerctl udiskie polkit-kde-agent-1
        network-manager-gnome blueman pavucontrol grim slurp hyprsunset
        nautilus qt5ct qt6ct xdg-user-dirs xdg-desktop-portal-gtk gvfs tumbler btop
        hyprlock hypridle hyprpaper grimblast
    )

    local missing=()
    local pkg
    for pkg in "${packages[@]}"; do
        if ! sudo apt install -y "$pkg" >/dev/null 2>&1; then
            missing+=("$pkg")
            log_warning "Package not available: $pkg"
        fi
    done

    # swayosd is not available in Ubuntu noble repos/ppa in many cases.
    # Build from source when missing.
    if ! command_exists swayosd; then
        log_warning "swayosd package not available, installing from source..."
        sudo apt install -y --no-install-recommends meson ninja-build cmake pkg-config \
            libgtk-3-dev libpulse-dev libdbusmenu-gtk3-dev libevdev-dev \
            libwayland-dev wayland-protocols scdoc gettext >/dev/null 2>&1 || true

        rm -rf /tmp/SwayOSD
        git clone https://github.com/ErikReider/SwayOSD.git /tmp/SwayOSD >/dev/null 2>&1 || true
        if [ -d /tmp/SwayOSD ]; then
            if [ -f /tmp/SwayOSD/install.sh ]; then
                (cd /tmp/SwayOSD && ./install.sh >/dev/null 2>&1) || true
            else
                (cd /tmp/SwayOSD && meson setup build >/dev/null 2>&1 && \
                    ninja -C build >/dev/null 2>&1 && sudo ninja -C build install >/dev/null 2>&1) || true
            fi
            rm -rf /tmp/SwayOSD
        fi

        if command_exists swayosd; then
            log_success "swayosd installed from source"
        else
            log_warning "Could not install swayosd automatically"
        fi
    fi

    if [ ${#missing[@]} -gt 0 ]; then
        log_warning "Missing Hyprland-related packages: ${missing[*]}"
        log_warning "Some packages may require extra repos/PPAs"
    fi
    
    # Setup Flatpak
    sudo flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo || true
    
    log_success "Hyprland packages installed"
}
{{- end }}

{{- else if .is_arch }}
# ============================================
# Arch Linux Package Installation
# ============================================

# Ensure AUR helper is available
ensure_aur_helper() {
    if command_exists yay || command_exists paru; then
        return 0
    fi
    
    log_info "Installing yay AUR helper..."
    git clone https://aur.archlinux.org/yay-bin.git /tmp/yay-bin
    (cd /tmp/yay-bin && makepkg -si --noconfirm)
    rm -rf /tmp/yay-bin
    log_success "yay installed"
}

install_aur() {
    if command_exists paru; then
        paru -S --noconfirm --needed "$@"
    elif command_exists yay; then
        yay -S --noconfirm --needed "$@"
    else
        log_error "No AUR helper found"
        return 1
    fi
}

install_base_packages() {
    log_info "Installing base packages (Arch)..."
    sudo pacman -Sy --noconfirm --needed \
        zsh git stow tmux curl wget xclip \
        fzf fd ripgrep lazygit zoxide \
        base-devel python-pip unzip fontconfig
    
    ensure_aur_helper
    log_success "Base packages installed"
}

install_neovim() {
    if command_exists nvim; then
        log_warning "Neovim already installed: $(nvim --version | head -n1)"
        return 0
    fi
    
    log_info "Installing Neovim..."
    sudo pacman -S --noconfirm neovim
    log_success "Neovim installed"
}

install_ghostty() {
    if command_exists ghostty; then
        log_warning "Ghostty already installed"
        return 0
    fi
    
    log_info "Installing Ghostty..."
    sudo pacman -S --noconfirm ghostty
    log_success "Ghostty installed"
}

install_awscli() {
    if command_exists aws; then
        log_warning "AWS CLI already installed: $(aws --version 2>&1 | head -n1)"
        return 0
    fi

    log_info "Installing AWS CLI (Arch package)..."
    sudo pacman -S --noconfirm --needed aws-cli
    log_success "AWS CLI installed: $(aws --version 2>&1 | head -n1)"
}

{{- if .install_desktop }}
install_desktop_packages() {
    log_info "Installing desktop packages (Arch)..."
    local repo_packages=(
        loupe gnome-text-editor file-roller
        seahorse mpv flatpak aws-cli
        curl jq tree btop iotop nethogs sshfs
        reflector pkgfile pacman-contrib
    )
    local pkg
    local missing=()

    for pkg in "${repo_packages[@]}"; do
        if ! sudo pacman -S --noconfirm --needed "$pkg" >/dev/null 2>&1; then
            missing+=("$pkg")
            log_warning "Package not available: $pkg"
        fi
    done

    if [ ${#missing[@]} -gt 0 ]; then
        log_warning "Missing Arch desktop packages: ${missing[*]}"
    fi
    
    install_aur gnome-firmware session-manager-plugin rate-mirrors paru || true
    sudo pkgfile --update 2>/dev/null || true
    
    log_success "Desktop packages installed"
}

install_hyprland_packages() {
    log_info "Installing Hyprland packages (Arch)..."
    local repo_packages=(
        waybar rofi-wayland wlogout cliphist wl-clipboard brightnessctl
        playerctl udiskie polkit-kde-agent network-manager-applet blueman pavucontrol
        grim slurp hyprlock hypridle hyprpaper hyprsunset nautilus qt5ct qt6ct
        xdg-user-dirs xdg-desktop-portal-gtk gvfs tumbler btop
    )

    local aur_packages=(swaync swayosd-git grimblast-git hyprshot rofi-calc)
    local missing=()
    local pkg

    for pkg in "${repo_packages[@]}"; do
        if ! sudo pacman -S --noconfirm --needed "$pkg" >/dev/null 2>&1; then
            missing+=("$pkg")
            log_warning "Package not available: $pkg"
        fi
    done

    if [ ${#missing[@]} -gt 0 ]; then
        log_warning "Missing Arch repo packages: ${missing[*]}"
    fi
    
    install_aur "${aur_packages[@]}" || true
    
    # Setup Flatpak
    sudo flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo || true
    
    log_success "Hyprland packages installed"
}
{{- end }}

{{- else }}
# ============================================
# Unsupported Distribution
# ============================================

install_base_packages() {
    log_error "Unsupported distribution: {{ .osid }}"
    log_info "Please install packages manually"
    return 1
}

install_neovim() {
    log_warning "Neovim installation not configured for {{ .osid }}"
}

install_ghostty() {
    log_warning "Ghostty installation not configured for {{ .osid }}"
}

install_awscli() {
    log_warning "AWS CLI installation not configured for {{ .osid }}"
}

{{- if .install_desktop }}
install_desktop_packages() {
    log_warning "Desktop packages not configured for {{ .osid }}"
}

install_hyprland_packages() {
    log_warning "Hyprland packages not configured for {{ .osid }}"
}
{{- end }}

{{- end }}

# ============================================
# Main Installation
# ============================================

main() {
    log_info "Starting system package installation..."
    log_info "Distribution: {{ .osid }}"
    log_info "Install desktop: {{ .install_desktop }}"
    log_info "Install K8s tools: {{ .install_k8s }}"
    
    install_base_packages
    install_neovim
    install_ghostty
    install_awscli
    
{{- if .install_desktop }}
    install_desktop_packages
    install_hyprland_packages
{{- end }}
    
    log_success "System package installation complete"
}

main "$@"
