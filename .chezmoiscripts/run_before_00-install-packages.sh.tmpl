{{- /* Install system packages based on distro and user preferences */ -}}
{{- /* packages.yaml hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }} */ -}}
#!/bin/bash
set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

command_exists() {
    command -v "$1" &> /dev/null
}

# ============================================
# Package Lists from .chezmoidata/packages.yaml
# ============================================

# System packages - common across distros
SYSTEM_COMMON=(
{{- range .packages.system.common }}
    "{{ . }}"
{{- end }}
)

{{- if .is_debian }}
# Debian/Ubuntu specific packages
SYSTEM_DISTRO=(
{{- range .packages.system.debian }}
    "{{ . }}"
{{- end }}
)
{{- else if .is_arch }}
# Arch specific packages
SYSTEM_DISTRO=(
{{- range .packages.system.arch }}
    "{{ . }}"
{{- end }}
)
{{- else }}
SYSTEM_DISTRO=()
{{- end }}

{{- if .install_desktop }}
# Desktop packages - common
DESKTOP_COMMON=(
{{- range .packages.desktop.common }}
    "{{ . }}"
{{- end }}
)

{{- if .is_debian }}
DESKTOP_DISTRO=(
{{- range .packages.desktop.debian }}
    "{{ . }}"
{{- end }}
)
{{- else if .is_arch }}
DESKTOP_DISTRO=(
{{- range .packages.desktop.arch }}
    "{{ . }}"
{{- end }}
)
{{- else }}
DESKTOP_DISTRO=()
{{- end }}

# Hyprland packages - common
HYPRLAND_COMMON=(
{{- range .packages.hyprland.common }}
    "{{ . }}"
{{- end }}
)

{{- if .is_debian }}
HYPRLAND_DISTRO=(
{{- range .packages.hyprland.debian }}
    "{{ . }}"
{{- end }}
)
{{- else if .is_arch }}
HYPRLAND_DISTRO=(
{{- range .packages.hyprland.arch }}
    "{{ . }}"
{{- end }}
)
HYPRLAND_AUR=(
{{- range .packages.hyprland.aur }}
    "{{ . }}"
{{- end }}
)
{{- else }}
HYPRLAND_DISTRO=()
HYPRLAND_AUR=()
{{- end }}

# Flatpak applications
FLATPAK_APPS=(
{{- range .packages.flatpak }}
    "{{ . }}"
{{- end }}
)
{{- end }}

{{- if .install_niri }}
# Niri/Noctalia packages
NIRI_COMMON=(
{{- range .packages.niri.common }}
    "{{ . }}"
{{- end }}
)

{{- if eq .osid "ubuntu" }}
NIRI_DISTRO=(
{{- range .packages.niri.ubuntu }}
    "{{ . }}"
{{- end }}
)
{{- else if .is_arch }}
NIRI_DISTRO=(
{{- range .packages.niri.arch }}
    "{{ . }}"
{{- end }}
)
NIRI_AUR=(
{{- range .packages.niri.aur }}
    "{{ . }}"
{{- end }}
)
{{- else }}
NIRI_DISTRO=()
NIRI_AUR=()
{{- end }}
{{- end }}

# ============================================
# Installation Functions
# ============================================

{{- if .is_debian }}
install_packages_apt() {
    local packages=("$@")
    local to_install=()
    local pkg

    for pkg in "${packages[@]}"; do
        if ! dpkg -l "$pkg" &>/dev/null; then
            to_install+=("$pkg")
        fi
    done

    if [ ${#to_install[@]} -gt 0 ]; then
        log_info "Installing: ${to_install[*]}"
        sudo apt install -y "${to_install[@]}" || {
            # Try installing one by one if batch fails
            for pkg in "${to_install[@]}"; do
                sudo apt install -y "$pkg" 2>/dev/null || log_warning "Failed to install: $pkg"
            done
        }
    fi
}

install_base_packages() {
    log_info "Installing base packages (Debian/Ubuntu)..."
    sudo apt update
    install_packages_apt "${SYSTEM_COMMON[@]}" "${SYSTEM_DISTRO[@]}"
    
    # fd-find symlink (Ubuntu names it differently)
    if command_exists fdfind && ! command_exists fd; then
        sudo ln -sf "$(which fdfind)" /usr/local/bin/fd
    fi
    
    log_success "Base packages installed"
}

install_neovim() {
    if command_exists nvim; then
        log_warning "Neovim already installed: $(nvim --version | head -n1)"
        return 0
    fi
    
    log_info "Installing Neovim..."
    sudo add-apt-repository -y ppa:neovim-ppa/unstable
    sudo apt update
    sudo apt install -y neovim
    log_success "Neovim installed"
}

install_ghostty() {
    if command_exists ghostty; then
        log_warning "Ghostty already installed"
        return 0
    fi
    
    log_info "Installing Ghostty..."
    
    # Add mkasberg/ghostty-ubuntu PPA
    if ! grep -qR "mkasberg/ghostty" /etc/apt/sources.list /etc/apt/sources.list.d 2>/dev/null; then
        sudo add-apt-repository -y ppa:mkasberg/ghostty-ubuntu
        sudo apt update
    fi
    
    # Try to install from PPA first
    if sudo apt install -y ghostty 2>/dev/null; then
        if command_exists ghostty; then
            sudo update-alternatives --install /usr/bin/x-terminal-emulator x-terminal-emulator /usr/bin/ghostty 50 2>/dev/null || true
            log_success "Ghostty installed via PPA"
            return 0
        fi
    fi
    
    # Fallback: download .deb directly from GitHub releases
    # Some Ubuntu versions may not be in the latest release
    log_info "PPA package not available, trying direct .deb download..."
    
    local arch
    arch=$(dpkg --print-architecture)
    source /etc/os-release
    
    # Try latest release first, then fall back to specific version for 25.04
    local deb_url="https://github.com/mkasberg/ghostty-ubuntu/releases/latest/download/ghostty_${arch}_${VERSION_ID}.deb"
    
    if ! curl -fsSL "$deb_url" -o /tmp/ghostty.deb 2>/dev/null; then
        # 25.04 support was in version 1.1.3-0-ppa2 but dropped in later versions
        if [ "$VERSION_ID" = "25.04" ]; then
            log_info "Trying older release with 25.04 support..."
            deb_url="https://github.com/mkasberg/ghostty-ubuntu/releases/download/1.1.3-0-ppa2/ghostty_1.1.3-0.ppa2_${arch}_25.04.deb"
            curl -fsSL "$deb_url" -o /tmp/ghostty.deb 2>/dev/null || true
        fi
    fi
    
    if [ -f /tmp/ghostty.deb ]; then
        if sudo dpkg -i /tmp/ghostty.deb 2>/dev/null || sudo apt-get install -f -y 2>/dev/null; then
            rm -f /tmp/ghostty.deb
            if command_exists ghostty; then
                sudo update-alternatives --install /usr/bin/x-terminal-emulator x-terminal-emulator /usr/bin/ghostty 50 2>/dev/null || true
                log_success "Ghostty installed via direct .deb download"
                return 0
            fi
        fi
        rm -f /tmp/ghostty.deb
    fi
    
    log_warning "Ghostty installation failed"
    log_info "Check https://github.com/mkasberg/ghostty-ubuntu/releases for supported versions"
    return 0
}

install_awscli() {
    if command_exists aws; then
        log_warning "AWS CLI already installed: $(aws --version 2>&1 | head -n1)"
        return 0
    fi

    log_info "Installing AWS CLI v2 (official installer)..."
    local arch aws_zip
    arch="$(uname -m)"

    case "$arch" in
        x86_64)  aws_zip="awscli-exe-linux-x86_64.zip" ;;
        aarch64|arm64) aws_zip="awscli-exe-linux-aarch64.zip" ;;
        *) log_warning "Unsupported architecture: $arch"; return 0 ;;
    esac

    cd /tmp
    curl -fsSL "https://awscli.amazonaws.com/${aws_zip}" -o awscliv2.zip
    unzip -q -o awscliv2.zip
    sudo ./aws/install --bin-dir /usr/local/bin --install-dir /usr/local/aws-cli --update
    rm -rf /tmp/aws /tmp/awscliv2.zip

    command_exists aws && log_success "AWS CLI installed: $(aws --version 2>&1 | head -n1)"
}

{{- if .install_desktop }}
install_desktop_packages() {
    log_info "Installing desktop packages (Debian/Ubuntu)..."
    install_packages_apt "${DESKTOP_COMMON[@]}" "${DESKTOP_DISTRO[@]}"
    log_success "Desktop packages installed"
}

install_hyprland_packages() {
    log_info "Installing Hyprland packages (Debian/Ubuntu)..."

    # Add Hyprland PPA if not present
    if ! grep -qR "cppiber/hyprland" /etc/apt/sources.list /etc/apt/sources.list.d 2>/dev/null; then
        log_info "Adding Hyprland PPA..."
        sudo add-apt-repository -y ppa:cppiber/hyprland
        sudo apt update
    fi

    install_packages_apt "${HYPRLAND_COMMON[@]}" "${HYPRLAND_DISTRO[@]}"

    # Install grimblast manually (not in Ubuntu repos)
    if ! command_exists grimblast; then
        log_info "Installing grimblast..."
        if curl -fsSL https://raw.githubusercontent.com/hyprwm/contrib/main/grimblast/grimblast -o /tmp/grimblast; then
            sudo install -Dm755 /tmp/grimblast /usr/local/bin/grimblast
            rm -f /tmp/grimblast
        fi
    fi

    # Setup Flatpak
    sudo flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo || true
    
    log_success "Hyprland packages installed"
}

install_flatpak_apps() {
    if ! command_exists flatpak; then
        log_warning "Flatpak not installed, skipping apps"
        return 0
    fi

    log_info "Installing Flatpak applications..."
    for app in "${FLATPAK_APPS[@]}"; do
        flatpak install -y flathub "$app" 2>/dev/null || log_warning "Failed to install: $app"
    done
    log_success "Flatpak applications installed"
}
{{- end }}

{{- if .install_niri }}
build_noctalia_qs() {
    # Build noctalia-qs (quickshell fork) from source.
    # Used on distros where the noctalia APT repo is not yet available.
    # https://github.com/noctalia-dev/noctalia-qs/blob/master/BUILD.md
    if command_exists qs; then
        log_info "noctalia-qs (qs) already installed, skipping build"
        return 0
    fi

    log_info "Building noctalia-qs from source (this may take a while)..."

    # Build dependencies (Ubuntu package names)
    local build_deps=(
        cmake ninja-build pkg-config git clang
        qt6-base-dev qt6-base-private-dev
        qt6-declarative-dev qt6-declarative-private-dev
        qt6-wayland-dev qt6-wayland-private-dev
        qt6-shadertools-dev qt6-svg-dev
        libdrm-dev libgbm-dev libvulkan-dev
        libwayland-dev wayland-protocols
        libxcb1-dev
        libpipewire-0.3-dev
        libpam0g-dev
        libpolkit-agent-1-dev libglib2.0-dev
        libjemalloc-dev libunwind-dev
        libcli11-dev spirv-tools
    )
    install_packages_apt "${build_deps[@]}"

    local build_dir
    build_dir=$(mktemp -d)
    trap "rm -rf ${build_dir}" RETURN

    log_info "Cloning noctalia-qs..."
    git clone --depth=1 https://github.com/noctalia-dev/noctalia-qs.git "${build_dir}/noctalia-qs"

    log_info "Configuring build..."
    cmake -GNinja \
        -B "${build_dir}/build" \
        -S "${build_dir}/noctalia-qs" \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DCMAKE_C_COMPILER=clang \
        -DCMAKE_CXX_COMPILER=clang++ \
        -DDISTRIBUTOR="dotfiles-build" \
        -DVENDOR_CPPTRACE=ON

    log_info "Building noctalia-qs..."
    cmake --build "${build_dir}/build"

    log_info "Installing noctalia-qs..."
    sudo cmake --install "${build_dir}/build"

    log_success "noctalia-qs built and installed to /usr/local/bin/qs"
}

install_niri_packages() {
    log_info "Installing Niri + Noctalia packages (Ubuntu)..."

    # Add niri PPA if not present
    if ! grep -qR "avengemedia/danklinux" /etc/apt/sources.list /etc/apt/sources.list.d 2>/dev/null; then
        log_info "Adding niri PPA..."
        sudo add-apt-repository -y ppa:avengemedia/danklinux
        sudo apt update
    fi

    # Detect Ubuntu codename
    local codename
    codename=$(. /etc/os-release && echo "${UBUNTU_CODENAME:-${VERSION_CODENAME}}")

    # Check if codename is supported by noctalia APT repo
    local supported_codenames=("trixie" "sid" "plucky" "questing")
    local noctalia_apt_supported=false
    for c in "${supported_codenames[@]}"; do
        if [ "${codename}" = "${c}" ]; then
            noctalia_apt_supported=true
            break
        fi
    done

    if [ "${noctalia_apt_supported}" = true ]; then
        # Supported distro: add noctalia APT repo and install noctalia-shell via apt
        if [ ! -f /etc/apt/keyrings/noctalia.gpg ]; then
            log_info "Adding Noctalia APT repository..."
            sudo mkdir -p /etc/apt/keyrings
            curl -fsSL https://pkg.noctalia.dev/gpg.key | sudo gpg --dearmor -o /etc/apt/keyrings/noctalia.gpg
            echo "deb [signed-by=/etc/apt/keyrings/noctalia.gpg] https://pkg.noctalia.dev/apt ${codename} main" \
                | sudo tee /etc/apt/sources.list.d/noctalia.list
            sudo apt update
        fi
        install_packages_apt "${NIRI_COMMON[@]}" "${NIRI_DISTRO[@]}"
    else
        # Unsupported distro (e.g. Ubuntu 26.04 resolute): install niri + deps from distro repos,
        # build noctalia-qs from source, download noctalia shell config manually.
        # https://docs.noctalia.dev/getting-started/installation/#manual-install
        log_info "Noctalia APT repo does not support '${codename}' yet — using manual install path..."

        # niri from PPA + common packages + noctalia runtime deps from distro repos
        local noctalia_runtime_deps=(
            brightnessctl        # laptop/internal monitor brightness
            imagemagick          # wallpaper resizing + template processing
            ddcutil              # desktop/external monitor brightness
            cliphist             # clipboard history
            wlsunset             # night light
            evolution-data-server  # calendar widget
        )
        install_packages_apt "${NIRI_COMMON[@]}" niri "${noctalia_runtime_deps[@]}"

        # Build noctalia-qs from source (Qt runtime / quickshell fork)
        build_noctalia_qs

        # Download noctalia shell config to ~/.config/quickshell/noctalia-shell
        local noctalia_config_dir="${HOME}/.config/quickshell/noctalia-shell"
        if [ ! -d "${noctalia_config_dir}" ]; then
            log_info "Downloading noctalia shell config..."
            mkdir -p "${noctalia_config_dir}"
            curl -sL https://github.com/noctalia-dev/noctalia-shell/releases/latest/download/noctalia-latest.tar.gz \
                | tar -xz --strip-components=1 -C "${noctalia_config_dir}"
            log_success "Noctalia shell config installed to ${noctalia_config_dir}"
        else
            log_info "Noctalia shell config already present, skipping download"
        fi
    fi

    log_success "Niri + Noctalia packages installed"
}
{{- end }}

{{- else if .is_arch }}
# Arch Linux functions

ensure_aur_helper() {
    if command_exists paru || command_exists yay; then
        return 0
    fi
    
    log_info "Installing yay AUR helper..."
    git clone https://aur.archlinux.org/yay-bin.git /tmp/yay-bin
    (cd /tmp/yay-bin && makepkg -si --noconfirm)
    rm -rf /tmp/yay-bin
    log_success "yay installed"
}

install_aur() {
    if command_exists paru; then
        paru -S --noconfirm --needed --skipreview --removemake "$@"
    elif command_exists yay; then
        yay -S --noconfirm --needed --answerclean None --answerdiff None --removemake "$@"
    else
        log_error "No AUR helper found"
        return 1
    fi
}

install_packages_pacman() {
    local packages=("$@")
    local to_install=()
    local pkg

    for pkg in "${packages[@]}"; do
        if ! pacman -Qi "$pkg" &>/dev/null; then
            to_install+=("$pkg")
        fi
    done

    if [ ${#to_install[@]} -gt 0 ]; then
        log_info "Installing: ${to_install[*]}"
        sudo pacman -S --noconfirm --needed "${to_install[@]}" || {
            for pkg in "${to_install[@]}"; do
                sudo pacman -S --noconfirm --needed "$pkg" 2>/dev/null || log_warning "Failed to install: $pkg"
            done
        }
    fi
}

install_base_packages() {
    log_info "Installing base packages (Arch)..."
    sudo pacman -Sy
    install_packages_pacman "${SYSTEM_COMMON[@]}" "${SYSTEM_DISTRO[@]}"
    ensure_aur_helper
    log_success "Base packages installed"
}

install_neovim() {
    if command_exists nvim; then
        log_warning "Neovim already installed: $(nvim --version | head -n1)"
        return 0
    fi
    
    log_info "Installing Neovim..."
    sudo pacman -S --noconfirm neovim
    log_success "Neovim installed"
}

install_ghostty() {
    if command_exists ghostty; then
        log_warning "Ghostty already installed"
        return 0
    fi
    
    log_info "Installing Ghostty..."
    sudo pacman -S --noconfirm ghostty
    log_success "Ghostty installed"
}

install_awscli() {
    if command_exists aws; then
        log_warning "AWS CLI already installed"
        return 0
    fi

    log_info "Installing AWS CLI..."
    sudo pacman -S --noconfirm --needed aws-cli
    log_success "AWS CLI installed"
}

{{- if .install_desktop }}
install_desktop_packages() {
    log_info "Installing desktop packages (Arch)..."
    install_packages_pacman "${DESKTOP_COMMON[@]}" "${DESKTOP_DISTRO[@]}"
    
    # Install AUR packages for desktop
    install_aur gnome-firmware session-manager-plugin rate-mirrors paru 2>/dev/null || true
    sudo pkgfile --update 2>/dev/null || true
    
    log_success "Desktop packages installed"
}

install_hyprland_packages() {
    log_info "Installing Hyprland packages (Arch)..."
    install_packages_pacman "${HYPRLAND_COMMON[@]}" "${HYPRLAND_DISTRO[@]}"
    
    # Install AUR packages
    if [ ${#HYPRLAND_AUR[@]} -gt 0 ]; then
        log_info "Installing Hyprland AUR packages..."
        install_aur "${HYPRLAND_AUR[@]}" || true
    fi
    
    # Setup Flatpak
    sudo flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo || true
    
    log_success "Hyprland packages installed"
}

install_flatpak_apps() {
    if ! command_exists flatpak; then
        log_warning "Flatpak not installed, skipping apps"
        return 0
    fi

    log_info "Installing Flatpak applications..."
    for app in "${FLATPAK_APPS[@]}"; do
        flatpak install -y flathub "$app" 2>/dev/null || log_warning "Failed to install: $app"
    done
    log_success "Flatpak applications installed"
}
{{- end }}

{{- if .install_niri }}
install_niri_packages() {
    log_info "Installing Niri + Noctalia packages (Arch)..."
    install_packages_pacman "${NIRI_COMMON[@]}" "${NIRI_DISTRO[@]}"

    if [ ${#NIRI_AUR[@]} -gt 0 ]; then
        log_info "Installing Noctalia AUR packages..."
        install_aur "${NIRI_AUR[@]}" || true
    fi

    log_success "Niri + Noctalia packages installed"
}
{{- end }}

{{- else }}
# Unsupported distribution

install_base_packages() {
    log_error "Unsupported distribution: {{ .osid }}"
    log_info "Please install packages manually"
    return 1
}

install_neovim() { log_warning "Neovim: manual install required for {{ .osid }}"; }
install_ghostty() { log_warning "Ghostty: manual install required for {{ .osid }}"; }
install_awscli() { log_warning "AWS CLI: manual install required for {{ .osid }}"; }
{{- if .install_desktop }}
install_desktop_packages() { log_warning "Desktop packages: manual install required"; }
install_hyprland_packages() { log_warning "Hyprland packages: manual install required"; }
install_flatpak_apps() { log_warning "Flatpak apps: manual install required"; }
{{- end }}

{{- end }}

# ============================================
# Common Functions (all distros)
# ============================================

install_uv() {
    if command_exists uv && command_exists uvx; then
        log_warning "uv already installed: $(uv --version 2>/dev/null || true)"
        return 0
    fi

    log_info "Installing uv..."
    curl -LsSf https://astral.sh/uv/install.sh | sh

    if command_exists uv || [ -x "$HOME/.local/bin/uv" ]; then
        log_success "uv installed"
    else
        log_warning "uv installation may need shell restart"
    fi
}

install_linuxbrew() {
    if [ -x "/home/linuxbrew/.linuxbrew/bin/brew" ] || command_exists brew; then
        log_warning "Homebrew already installed"
        return 0
    fi

    log_info "Installing Homebrew (Linux)..."
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" || {
        log_warning "Homebrew installation failed"
        return 0
    }

    [ -x "/home/linuxbrew/.linuxbrew/bin/brew" ] && log_success "Homebrew installed"
}

# ============================================
# Main Installation
# ============================================

main() {
    log_info "Starting system package installation..."
    log_info "Distribution: {{ .osid }}"
    log_info "Install desktop: {{ .install_desktop }}"
    log_info "Install Niri: {{ .install_niri }}"
    log_info "Install K8s tools: {{ .install_k8s }}"
    
    install_base_packages
    install_neovim
    install_ghostty
    install_awscli
    install_uv
    install_linuxbrew
    
{{- if .install_desktop }}
    install_desktop_packages
    install_hyprland_packages
    install_flatpak_apps
{{- end }}

{{- if .install_niri }}
    install_niri_packages
{{- end }}
    
    log_success "System package installation complete"
    log_info "Note: mise-managed tools (bat, delta, eza, k8s tools) will be installed by mise"
}

main "$@"
