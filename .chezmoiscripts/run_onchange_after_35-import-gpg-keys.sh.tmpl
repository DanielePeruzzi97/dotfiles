{{- if not .personal -}}{{ "" }}{{- else -}}
#!/usr/bin/env bash
# Import GPG private keys into the local keyring if not already present.
# Uses age-encrypted key files from the chezmoi source dir (never written to disk).
# Re-runs when source .age files change (sha256 embedded below by chezmoi).
# {{ include "gpg-keys/encrypted_private_gpg_personal.pgp.age" | sha256sum }}
# {{ include "gpg-keys/encrypted_private_gpg_work.pgp.age" | sha256sum }}
set -euo pipefail

info() { printf "\033[0;34m[*]\033[0m %s\n" "$*"; }
ok()   { printf "\033[0;32m[+]\033[0m %s\n" "$*"; }
warn() { printf "\033[1;33m[!]\033[0m %s\n" "$*"; }

IDENTITY="{{ .chezmoi.homeDir }}/.config/chezmoi/key.txt"
SRC="{{ .chezmoi.sourceDir }}/gpg-keys"

import_key() {
    local key_id="$1" age_file="$SRC/$2"
    if gpg --list-secret-keys "$key_id" &>/dev/null; then
        ok "GPG key $key_id already in keyring"
        return 0
    fi
    if [ ! -f "$age_file" ]; then
        warn "GPG key file not found: $age_file — skipping"
        return 0
    fi
    info "Importing GPG key $key_id"
    age -d -i "$IDENTITY" "$age_file" | gpg --import --batch
    ok "GPG key $key_id imported"
}

import_key 1395B76D386CE4BA encrypted_private_gpg_personal.pgp.age
import_key B14E233ED2FF6215 encrypted_private_gpg_work.pgp.age
{{- end }}
