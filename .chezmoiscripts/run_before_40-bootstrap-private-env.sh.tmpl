#!/bin/bash
# Decrypt optional bootstrap env from YubiKey-protected age file.
# This is used to provide secrets like GITHUB_TOKEN during bootstrap
# without committing plaintext values.

set -e

YELLOW='\033[1;33m'
BLUE='\033[0;34m'
GREEN='\033[0;32m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[WARN]${NC} $1"; }

SOURCE_DIR="$HOME/.dotfiles"
ENCRYPTED_ENV="$SOURCE_DIR/bootstrap.private.env.age"
STATE_DIR="$HOME/.local/share/dotfiles"
DECRYPTED_ENV="$STATE_DIR/bootstrap.private.env"

if [ ! -f "$ENCRYPTED_ENV" ]; then
    exit 0
fi

mkdir -p "$STATE_DIR"

if ! command -v age >/dev/null 2>&1; then
{{- if .is_debian }}
    log_info "Installing age for bootstrap secret decryption..."
    sudo apt install -y age >/dev/null 2>&1 || {
        log_warning "Could not install age, skipping bootstrap private env"
        exit 0
    }
{{- else if .is_arch }}
    log_info "Installing age for bootstrap secret decryption..."
    sudo pacman -S --noconfirm --needed age >/dev/null 2>&1 || {
        log_warning "Could not install age, skipping bootstrap private env"
        exit 0
    }
{{- else }}
    log_warning "age not installed, skipping bootstrap private env"
    exit 0
{{- end }}
fi

YUBIKEY_IDENTITY_FILE="$HOME/.config/age/yubikey-identities.txt"

if ! command -v age-plugin-yubikey >/dev/null 2>&1; then
{{- if .is_debian }}
    log_info "Installing dependencies for age-plugin-yubikey..."
    sudo apt install -y --no-install-recommends \
        cargo pkg-config libpcsclite-dev pcscd scdaemon >/dev/null 2>&1 || {
        log_warning "Could not install age-plugin-yubikey dependencies, skipping bootstrap private env"
        exit 0
    }
{{- else if .is_arch }}
    log_info "Installing dependencies for age-plugin-yubikey..."
    sudo pacman -S --noconfirm --needed \
        rust pkgconf pcsclite yubikey-manager >/dev/null 2>&1 || {
        log_warning "Could not install age-plugin-yubikey dependencies, skipping bootstrap private env"
        exit 0
    }
{{- end }}

    if command -v cargo >/dev/null 2>&1; then
        log_info "Installing age-plugin-yubikey..."
        cargo install age-plugin-yubikey --locked >/dev/null 2>&1 || {
            log_warning "Could not install age-plugin-yubikey, skipping bootstrap private env"
            exit 0
        }
        export PATH="$HOME/.cargo/bin:$PATH"
    fi
fi

if [ ! -f "$YUBIKEY_IDENTITY_FILE" ]; then
    mkdir -p "$HOME/.config/age"
    log_info "Generating YubiKey identity file..."
    if age-plugin-yubikey --identity > "$YUBIKEY_IDENTITY_FILE" 2>/dev/null; then
        chmod 600 "$YUBIKEY_IDENTITY_FILE"
    else
        rm -f "$YUBIKEY_IDENTITY_FILE"
        log_warning "Could not read YubiKey identity, skipping bootstrap private env"
        exit 0
    fi
fi

if [ ! -s "$YUBIKEY_IDENTITY_FILE" ]; then
    log_warning "YubiKey identity file is empty, skipping bootstrap private env"
    exit 0
fi

log_info "Decrypting bootstrap.private.env.age (may require YubiKey touch)..."
if age -d -i "$YUBIKEY_IDENTITY_FILE" -o "$DECRYPTED_ENV" "$ENCRYPTED_ENV" 2>/dev/null; then
    chmod 600 "$DECRYPTED_ENV"
    log_success "Bootstrap private env decrypted"
else
    log_warning "Could not decrypt bootstrap.private.env.age"
    log_warning "Skipping private env; bootstrap continues"
    exit 0
fi
