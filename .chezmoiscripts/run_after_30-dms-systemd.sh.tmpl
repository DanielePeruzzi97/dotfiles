{{- /* Enable DMS user service + tie to niri.service */ -}}
{{- if and (eq .profile "workstation") (not (env "CI")) -}}
#!/usr/bin/env bash
set -euo pipefail

info() { printf "\033[0;34m[*]\033[0m %s\n" "$*"; }
ok()   { printf "\033[0;32m[+]\033[0m %s\n" "$*"; }

if ! command -v dms >/dev/null; then
    echo "dms binary not found — skipping systemd integration"
    exit 0
fi

# Need a user-bus session; in a fresh VM during chezmoi apply this is usually fine,
# but be defensive: only run if the user systemd manager is up.
if ! systemctl --user show-environment >/dev/null 2>&1; then
    echo "user systemd not available in this context — skipping"
    exit 0
fi

info "Enabling dms user service (will start on next compositor session)"
systemctl --user enable dms.service 2>/dev/null || true

{{ if .want_niri -}}
info "Tying DMS to niri session (add-wants niri.service dms.service)"
systemctl --user add-wants niri.service dms.service || true
{{- end }}

{{ if .want_hyprland -}}
# DMS .deb post-install already symlinks dms.service into
# graphical-session.target.wants/, which any hyprland session pulls in.
# Only do an explicit add-wants if the target unit actually exists
# (newer hyprland builds ship hyprland-session.target; cppiber's PPA does not).
if systemctl --user list-unit-files hyprland-session.target 2>/dev/null | grep -q hyprland-session.target; then
    info "Tying DMS to hyprland session (add-wants hyprland-session.target dms.service)"
    systemctl --user add-wants hyprland-session.target dms.service || true
else
    info "hyprland-session.target absent (PPA build); relying on graphical-session.target symlink"
fi
{{- end }}

ok "DMS systemd integration done"
{{- else -}}
#!/usr/bin/env bash
exit 0
{{- end }}
