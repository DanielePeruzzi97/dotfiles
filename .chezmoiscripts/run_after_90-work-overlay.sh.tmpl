{{- if not .personal -}}{{ "" }}{{- else -}}
#!/usr/bin/env bash
# Clone/update dotfiles_work private repo and apply as chezmoi source overlay.
# Runs after run_after_10 so the personal SSH key is already deployed.
# Fails gracefully if SSH auth not yet available — retry with: chezmoi apply
set -euo pipefail

info() { printf "\033[0;34m[*]\033[0m %s\n" "$*"; }
ok()   { printf "\033[0;32m[+]\033[0m %s\n" "$*"; }
warn() { printf "\033[1;33m[!]\033[0m %s\n" "$*"; }

WORK_SRC="$HOME/.dotfiles_work"
WORK_REPO="git@github.com:DanielePeruzzi97/dotfiles_work.git"
SSH_KEY="{{ .chezmoi.homeDir }}/.ssh/id_ed25519"

# SSH sockets dir required by ControlMaster in 99-defaults.conf
mkdir -p "$HOME/.ssh/sockets"

# Use key directly — no ssh-agent required. If key has passphrase, ssh prompts on /dev/tty.
# ControlMaster disabled to avoid socket issues on first clone.
if [ -f "$SSH_KEY" ]; then
    export GIT_SSH_COMMAND="ssh -i $SSH_KEY -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new -o ControlMaster=no"
fi

if [ -d "$WORK_SRC/.git" ]; then
    info "Updating work dotfiles ($WORK_SRC)"
    git -C "$WORK_SRC" pull --ff-only \
        || warn "Work dotfiles pull failed — using existing checkout"
else
    info "Cloning work dotfiles → $WORK_SRC"
    if ! git clone "$WORK_REPO" "$WORK_SRC"; then
        warn "Could not clone $WORK_REPO"
        warn "Retry: chezmoi apply"
        exit 0
    fi
fi

# Apply work overlay — reuses ~/.config/chezmoi/chezmoi.toml (same age key + template data)
info "Applying work dotfiles overlay"
chezmoi apply --source="$WORK_SRC" --no-pager
ok "Work dotfiles applied"
{{- end }}
