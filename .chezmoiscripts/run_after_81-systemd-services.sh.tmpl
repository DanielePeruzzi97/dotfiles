#!/usr/bin/env bash
# Setup systemd user services
# Only runs on desktop machines

set -euo pipefail

{{- if not .is_desktop }}
exit 0
{{- end }}

echo "Setting up systemd user services..."

# Ensure user systemd directory exists
mkdir -p "$HOME/.config/systemd/user"

# HyprDynamicMonitors service
HDM_SERVICE_SRC="$HOME/.config/hyprdynamicmonitors/hyprdynamicmonitors.service"
HDM_SERVICE_DST="$HOME/.config/systemd/user/hyprdynamicmonitors.service"

if [ -f "$HDM_SERVICE_SRC" ]; then
    # Check if service file has changed
    if [ ! -f "$HDM_SERVICE_DST" ] || ! cmp -s "$HDM_SERVICE_SRC" "$HDM_SERVICE_DST"; then
        cp "$HDM_SERVICE_SRC" "$HDM_SERVICE_DST"
        systemctl --user daemon-reload
        echo "HyprDynamicMonitors service updated"
    fi
    
    # Enable the service
    if ! systemctl --user is-enabled hyprdynamicmonitors.service &>/dev/null; then
        systemctl --user enable hyprdynamicmonitors.service
        echo "HyprDynamicMonitors service enabled"
    fi
else
    echo "HyprDynamicMonitors service file not found, skipping"
fi

echo "Systemd user services setup complete"
