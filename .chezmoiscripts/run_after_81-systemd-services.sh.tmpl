#!/usr/bin/env bash
# Setup systemd user services
# Only runs on desktop machines

set -euo pipefail

{{- if not .install_desktop }}
exit 0
{{- end }}

echo "Setting up systemd user services..."

# Pick up chezmoi-managed user units from ~/.config/systemd/user
systemctl --user daemon-reload

CHEZMOI_SERVICES=(
    "hyprdynamicmonitors-prepare.service"
    "hyprdynamicmonitors.service"
)

PACKAGE_SERVICES=(
    "hypridle.service"
    "hyprpaper.service"
    "hyprpolkitagent.service"
    "hyprsunset.service"
)

for service in "${CHEZMOI_SERVICES[@]}"; do
    if systemctl --user list-unit-files "$service" &>/dev/null; then
        if ! systemctl --user is-enabled "$service" &>/dev/null; then
            systemctl --user enable "$service"
            echo "Enabled $service"
        fi
    else
        echo "Service $service not found, skipping"
    fi
done

for service in "${PACKAGE_SERVICES[@]}"; do
    if systemctl --user list-unit-files --type=service --all | grep -q "^$service"; then
        if ! systemctl --user is-enabled "$service" &>/dev/null; then
            systemctl --user enable "$service"
            echo "Enabled $service"
        fi
    else
        echo "Service $service not found, skipping"
    fi
done

echo "Systemd user services setup complete"
