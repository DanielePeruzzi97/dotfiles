{{- if not .personal -}}{{ "" }}{{- else -}}
#!/usr/bin/env bash
# Fetch age identity key from Bitwarden if not already present.
# Must run before chezmoi applies files so encrypted .age blobs can be decrypted.
set -euo pipefail

info() { printf "\033[0;34m[*]\033[0m %s\n" "$*"; }
ok()   { printf "\033[0;32m[+]\033[0m %s\n" "$*"; }
warn() { printf "\033[1;33m[!]\033[0m %s\n" "$*"; }
die()  { printf "\033[0;31m[!]\033[0m %s\n" "$*" >&2; exit 1; }

KEY_FILE="{{ .chezmoi.homeDir }}/.config/chezmoi/key.txt"

if [ -f "$KEY_FILE" ]; then
    ok "Age key already present at $KEY_FILE"
    exit 0
fi

info "Age key not found — fetching from Bitwarden (note: chezmoi-age-key)"

if ! command -v bw &>/dev/null; then
    die "Bitwarden CLI (bw) not found in PATH.
  Install it first, then re-run chezmoi apply:
    npm install -g @bitwarden/cli          # via npm
    flatpak run com.bitwarden.desktop      # GUI only, no CLI
  Or manually place your age key at: $KEY_FILE (mode 0600)"
fi

# Ensure logged in
if ! bw login --check &>/dev/null; then
    info "Bitwarden login required"
    bw login || die "Bitwarden login failed"
fi

# Unlock vault and fetch the age identity key
BW_SESSION=$(bw unlock --raw) || die "Bitwarden unlock failed"
export BW_SESSION

mkdir -p "$(dirname "$KEY_FILE")"
bw get notes "chezmoi-age-key" --session "$BW_SESSION" > "$KEY_FILE" \
    || die "Failed to fetch 'chezmoi-age-key' note from Bitwarden vault"
chmod 600 "$KEY_FILE"

ok "Age key written to $KEY_FILE"
{{- end }}
